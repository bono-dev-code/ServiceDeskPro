<Window x:Class="ServiceDeskPro.Views.RegisterCompanyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ServiceDesk Pro - Register Company" Height="660" Width="1080" MinHeight="620" MinWidth="960"
        WindowStartupLocation="CenterScreen" Background="{StaticResource AppBackground}"
        ResizeMode="CanResize" SizeToContent="Manual">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" Padding="26">
            <StackPanel VerticalAlignment="Center">
                <!-- Shared brand header used across the system for a consistent professional identity. -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                    <Border Width="52" Height="52" CornerRadius="10" Background="#333333" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                        <TextBlock Text="🎧" FontSize="27" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="ServiceDesk" FontSize="30" FontWeight="Bold"/>
                        <TextBlock Text="Pro" FontSize="30" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Professional IT support ticketing system for real organisations." TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="16" LineHeight="25"/>
                <TextBlock Text="First setup creates the company profile and the first Admin account." TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,34,0,0" LineHeight="23"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource CardBackground}" Padding="28" Margin="18,0,0,0" HorizontalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Register Company" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Create the organisation and main administrator account." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,16"/>

                    <TextBlock Text="Company Details" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Text="Company Name" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="CompanyNameBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Company Email" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="CompanyEmailBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Phone" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="PhoneBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Address" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="AddressBox" Margin="0,6,0,16"/>

                    <TextBlock Text="Admin Account" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Text="Full Name" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="FullNameBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Username" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="UsernameBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Admin Email" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="AdminEmailBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Password" Foreground="{StaticResource MutedTextBrush}"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,6,0,12"/>
                    <TextBlock Text="Confirm Password" Foreground="{StaticResource MutedTextBrush}"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,6,0,16"/>

                    <TextBlock x:Name="MessageText" Foreground="#EF4444" Margin="0,0,0,14"/>
                    <Button Content="Create Company Account" Style="{StaticResource PrimaryButton}" Height="46" Click="CreateCompany_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
