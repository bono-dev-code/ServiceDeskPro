<Window x:Class="ServiceDeskPro.Views.TicketDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket Details" Height="680" Width="920"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackground}">
    <Grid Margin="28">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="320"/></Grid.ColumnDefinitions>

        <Border Background="{StaticResource CardBackground}" Padding="22" Margin="0,0,18,0">
            <StackPanel>
                <TextBlock x:Name="TicketNumberText" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="TitleText" FontSize="18" Margin="0,8,0,12"/>
                <TextBlock x:Name="DescriptionText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" LineHeight="23" Margin="0,0,0,20"/>

                <UniformGrid Columns="2" Margin="0,0,0,20">
                    <StackPanel Margin="0,0,14,10"><TextBlock Text="Priority" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="PriorityText" FontWeight="SemiBold"/></StackPanel>
                    <StackPanel Margin="0,0,14,10"><TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="StatusText" FontWeight="SemiBold"/></StackPanel>
                    <StackPanel Margin="0,0,14,10"><TextBlock Text="Department" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="DepartmentText" FontWeight="SemiBold"/></StackPanel>
                    <StackPanel Margin="0,0,14,10"><TextBlock Text="Assigned To" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="AssignedText" FontWeight="SemiBold"/></StackPanel>
                    <StackPanel Margin="0,0,14,10"><TextBlock Text="Created By" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="CreatedByText" FontWeight="SemiBold"/></StackPanel>
                    <StackPanel Margin="0,0,14,10"><TextBlock Text="SLA" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="SlaText" FontWeight="SemiBold"/></StackPanel>
                </UniformGrid>

                <TextBlock Text="Add Progress Comment" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="CommentBox" Height="90" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>
                <Button Content="Add Comment" Style="{StaticResource PrimaryButton}" Height="42" Click="AddComment_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource CardBackground}" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Text="Assign Technician" Foreground="{StaticResource MutedTextBrush}"/>
                    <ComboBox x:Name="TechnicianBox" SelectedValuePath="UserId" TextSearch.TextPath="FullName" Margin="0,6,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <!-- Shows the real technician name instead of ServiceDeskPro.Models.User. -->
                                <TextBlock Text="{Binding FullName}" Foreground="White"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Assign" Style="{StaticResource SecondaryButton}" Click="Assign_Click" Margin="0,0,0,14"/>

                    <TextBlock Text="Update Status" Foreground="{StaticResource MutedTextBrush}"/>
                    <ComboBox x:Name="StatusBox" Margin="0,6,0,12"/>
                    <Button Content="Update Status" Style="{StaticResource SecondaryButton}" Click="UpdateStatus_Click" Margin="0,0,0,20"/>

                    <TextBlock Text="Comments" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                </StackPanel>
                <ListBox x:Name="CommentsListBox" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
