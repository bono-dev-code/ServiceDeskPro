<Window x:Class="ServiceDeskPro.Views.TechnicianEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Technician"
        Width="560"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252525">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#22C7D8"/>
        <SolidColorBrush x:Key="CardBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#2F2F2F"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#555555"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#CFCFCF"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox styling is inherited from App.xaml so every dropdown uses the same dark professional theme.
             This keeps selected values like Finance and On Break clearly visible. -->

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="28" Margin="18">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                <Button Content="Save Changes" Style="{StaticResource PrimaryButton}" Click="SaveChanges_Click"/>
                <Button Content="Delete Technician" Height="42" Margin="0,10,0,0" Background="#7F1D1D" Foreground="White" BorderBrush="#EF4444" Click="DeleteTechnician_Click"/>
                <Button Content="Cancel" Height="38" Margin="0,10,0,0" Background="#2F2F2F" Foreground="White" BorderBrush="{StaticResource BorderBrushSoft}" Click="Cancel_Click"/>
                <TextBlock x:Name="MessageText" Foreground="#86EFAC" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Edit Technician" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Update technician details, or delete the technician from the system." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,22"/>

                    <TextBlock Text="Full Name" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="FullNameBox" Margin="0,5,0,12"/>

                    <TextBlock Text="Email" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="EmailBox" Margin="0,5,0,12"/>

                    <TextBlock Text="Phone" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="PhoneBox" Margin="0,5,0,12"/>

                    <TextBlock Text="Department" Foreground="{StaticResource MutedTextBrush}"/>
                    <ComboBox x:Name="DepartmentBox" Margin="0,5,0,12"/>

                    <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}"/>
                    <ComboBox x:Name="StatusBox" Margin="0,5,0,4">
                        <ComboBoxItem Content="Available"/>
                        <ComboBoxItem Content="On Break"/>
                        <ComboBoxItem Content="Offline"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
