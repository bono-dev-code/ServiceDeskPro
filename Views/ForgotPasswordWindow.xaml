<Window x:Class="ServiceDeskPro.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ServiceDesk Pro - Forgot Password"
        Height="560" Width="760"
        MinHeight="520" MinWidth="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackground}">
    <Grid Margin="28">
        <Border Background="{StaticResource CardBackground}"
                Padding="36"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <!-- The same software identity is used here so the reset window feels part of the main system. -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="46" Height="46" CornerRadius="9"
                                Background="#333333"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1">
                            <TextBlock Text="🎧" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="ServiceDesk" FontSize="27" FontWeight="Bold"/>
                            <TextBlock Text="Pro" FontSize="27" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Forgot Password"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Verify your username and email, then create a new password."
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <!-- Step 1 asks for username and email. This is simple and works offline with SQLite. -->
                    <StackPanel x:Name="VerifyPanel"
                                VerticalAlignment="Top">
                        <TextBlock Text="Username" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="UsernameBox" Margin="0,6,0,16"/>

                        <TextBlock Text="Email Address" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="EmailBox" Margin="0,6,0,18"/>

                        <TextBlock x:Name="VerifyMessageText"
                                   Foreground="#EF4444"
                                   Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="120"
                                    Height="44"
                                    Margin="0,0,10,0"
                                    Click="Cancel_Click"/>
                            <Button Content="Verify Account"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="170"
                                    Height="44"
                                    Click="Verify_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Step 2 appears only after a valid username/email match is found. -->
                    <StackPanel x:Name="ResetPanel"
                                Visibility="Collapsed"
                                VerticalAlignment="Top">
                        <TextBlock x:Name="VerifiedUserText"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,22"/>

                        <TextBlock Text="New Password" Foreground="{StaticResource MutedTextBrush}"/>
                        <PasswordBox x:Name="NewPasswordBox" Margin="0,6,0,16"/>

                        <TextBlock Text="Confirm New Password" Foreground="{StaticResource MutedTextBrush}"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,6,0,18" KeyDown="ConfirmPasswordBox_KeyDown"/>

                        <TextBlock x:Name="ResetMessageText"
                                   Foreground="#EF4444"
                                   Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Back"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="120"
                                    Height="44"
                                    Margin="0,0,10,0"
                                    Click="Back_Click"/>
                            <Button Content="Save New Password"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="190"
                                    Height="44"
                                    Click="SavePassword_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
