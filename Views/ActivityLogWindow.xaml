<Window x:Class="ServiceDeskPro.Views.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ServiceDesk Pro - Activity Log"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackground}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Activity Log" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Complete history of important ServiceDesk Pro events." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#3A3A3A" BorderBrush="#444444" BorderThickness="1" CornerRadius="10" Padding="0">
            <DataGrid x:Name="ActivityGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      RowHeight="38"
                      GridLinesVisibility="Horizontal"
                      HorizontalScrollBarVisibility="Disabled">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date / Time" Binding="{Binding CreatedDate, StringFormat=g}" Width="160"/>
                    <DataGridTextColumn Header="Activity" Binding="{Binding Title}" Width="220"/>
                    <DataGridTextColumn Header="Details" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="2"
                Content="Close"
                Width="150"
                Height="42"
                HorizontalAlignment="Right"
                Margin="0,18,0,0"
                Style="{StaticResource SecondaryButton}"
                Click="Close_Click"/>
    </Grid>
</Window>
